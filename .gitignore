/.quarto/

# Allow docs folder for GitHub Pages, but ignore specific generated files
!docs/
!docs/**/*.html

# Ignore images and PDFs except in _assets/ and cv/ directories
**/*.jpg
**/*.jpeg
!_assets/**/*.jpg
!_assets/**/*.jpeg
**/*.pdf
!cv/**/*.pdf
!docs/cv/**/*.pdf

# System files
**/.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*~

# Editor files
.vscode/
.idea/
*.swp
*.swo
*.bak

# R and RStudio
.Rproj.user
.Rhistory
.RData
.Ruserdata
*.Rproj

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
.ipynb_checkpoints/
*.pyc

# Node
node_modules/
npm-debug.log
yarn-error.log

# Quarto
_site/
.quarto/
*_cache/
*_files/

# Temporary files
*.log
*.tmp
*.temp
.env
.env.local

# Auto-generated by pre-render scripts
_assets/bibliography/articles.bib
publications.qmd
cv/cv-pdf.qmd

